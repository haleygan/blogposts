direction: down

gcp: {
  label: "GCP"
  shape: rectangle
  style: {
    fill: "#ffffff"
    stroke: "#4285F4"
    stroke-width: 2
    border-radius: 8
    bold: true
  }

  pool: {
    label: "Workload Identity Pool"
    shape: rectangle
    style: {
      fill: "#E1F5EE"
      stroke: "#0F6E56"
      stroke-width: 2
      border-radius: 6
      bold: true
    }

    github_provider: {
      label: "Provider: GitHub Actions"
      shape: rectangle
      style: {
        fill: "#EEEDFE"
        stroke: "#534AB7"
        stroke-width: 1
        border-radius: 6
        bold: true
      }
    }
  }

  sts: {
    label: "Security Token Service (STS)"
    shape: rectangle
    style: {
      fill: "#E6F1FB"
      stroke: "#185FA5"
      stroke-width: 1
      border-radius: 6
      bold: true
      font-size: 13
    }

    sts_desc: {
      label: "Validates the incoming token (from Github) against the pool and provider config.\nIf valid, exchanges it for a short-lived federated token\nthat can then be used to request service account impersonation."
      shape: text
      style: {
        font-size: 12
        italic: true
        font-color: gray
        bold: false
      }
    }
  }

  service_account: {
    label: "Service Account"
    grid-rows: 2
    grid-gap: 16
    style: {
      fill: "#FEF3E2"
      stroke: "#BA7517"
      stroke-width: 2
      border-radius: 8
      bold: true
    }

    sa_identity: {
      label: "Identity\ngithub-actions-sa@my-project.iam.gserviceaccount.com"
      shape: rectangle
      style: {
        fill: "#ffffff"
        stroke: "#FAC775"
        border-radius: 4
        font-size: 13
        bold: false
      }
    }

    sa_role: {
      label: "GCP Resource Role\nroles/artifactregistry.writer"
      shape: rectangle
      style: {
        fill: "#ffffff"
        stroke: "#FAC775"
        border-radius: 4
        font-size: 13
        bold: false
      }
    }

    sa_role_desc: {
      label: "This is the role that grants access to GCP resources — in this example,\nArtifact Registry Writer allows pushing Docker images to Artifact Registry.\nSwap this for whatever role matches the access your external system needs."
      shape: text
      style: {
        font-size: 12
        italic: true
        font-color: gray
        bold: false
      }
    }
  }

  iam_binding: {
    label: "IAM Binding — attached to the Service Account"
    grid-rows: 3
    grid-gap: 16
    style: {
      fill: "#FAECE7"
      stroke: "#993C1D"
      stroke-width: 2
      border-radius: 8
      bold: true
    }

    binding_role: {
      label: "Role\nroles/iam.workloadIdentityUser"
      shape: rectangle
      style: {
        fill: "#ffffff"
        stroke: "#F0997B"
        border-radius: 4
        font-size: 13
        bold: false
      }
    }

    binding_role_desc: {
      label: "Grants the right to impersonate this service account.\nDoes not grant access to any GCP resource on its own."
      shape: text
      style: {
        font-size: 12
        italic: true
        font-color: gray
        bold: false
      }
    }

    binding_member: {
      label: "Member (principal)\nprincipalSet://iam.googleapis.com/projects/PROJECT_NUMBER/locations/global\n/workloadIdentityPools/POOL_ID/attribute.repository/my-org/my-repo"
      shape: rectangle
      style: {
        fill: "#ffffff"
        stroke: "#F0997B"
        border-radius: 4
        font-size: 13
        bold: false
      }
    }

    binding_member_desc: {
      label: "Scoped to a specific attribute from the token.\nOnly WIF identities whose token matches attribute.repository == my-org/my-repo\nare allowed to impersonate this service account.\nTokens that don't match are rejected before reaching the service account."
      shape: text
      style: {
        font-size: 12
        italic: true
        font-color: gray
        bold: false
      }
    }
  }

  pool -> sts: {
    label: "shares the validation method and passing criteria"
    style: {
      stroke: "#0F6E56"
      stroke-width: 1
    }
  }

  sts -> service_account: {
    label: "requests impersonation via generateAccessToken"
    style: {
      stroke: "#185FA5"
      stroke-width: 1
    }
  }

  iam_binding -> service_account: {
    label: "attached to — checks every impersonation request"
    style: {
      stroke: "#993C1D"
      stroke-width: 1
    }
  }
}
