direction: down

gcp: {
  label: "GCP"
  shape: rectangle
  style: {
    fill: "#ffffff"
    stroke: "#4285F4"
    stroke-width: 2
    border-radius: 8
    bold: true
  }

  pool: {
    label: "Workload Identity Pool"
    shape: rectangle
    style: {
      fill: "#E1F5EE"
      stroke: "#0F6E56"
      stroke-width: 2
      border-radius: 8
      bold: true
    }

    github_provider: {
      label: "Provider: GitHub Actions"
      shape: rectangle
      style: {
        fill: "#EEEDFE"
        stroke: "#534AB7"
        stroke-width: 1
        border-radius: 6
        bold: true
      }

      github_issuer: {
        label: "Issuer URL"
        grid-rows: 2
        grid-gap: 20
        style: {
          fill: "#f5f4fe"
          stroke: "#AFA9EC"
          border-radius: 4
          bold: true
        }

        issuer_value: {
          label: "https://token.actions.githubusercontent.com"
          shape: rectangle
          style: {
            fill: "#ffffff"
            stroke: "#AFA9EC"
            border-radius: 4
            font-size: 13
            bold: false
          }
        }

        issuer_desc: {
          label: "Where GCP fetches GitHub's public keys to verify that incoming tokens were \ngenuinely signed by GitHub."
          shape: text
          style: {
            font-size: 12
            font-color: gray
            bold: false
          }
        }
      }

      github_mapping: {
        label: "Attribute Mapping"
        grid-rows: 2
        grid-gap: 20
        style: {
          fill: "#f5f4fe"
          stroke: "#AFA9EC"
          border-radius: 4
          bold: true
        }

        mapping_value: {
          label: "google.subject = assertion.sub\nattribute.repository = assertion.repository\nattribute.repository_owner = assertion.repository_owner"
          shape: rectangle
          style: {
            fill: "#ffffff"
            stroke: "#AFA9EC"
            border-radius: 4
            font-size: 13
            bold: false
          }
        }

        mapping_desc: {
          label: "google.* and attribute.* are GCP's labels, assertion.* comes from the GitHub JWT.\nThis tells GCP how to find verification information from the provider's token."
          shape: text
          style: {
            font-size: 12
            font-color: gray
            bold: false
          }
        }
      }

      github_condition: {
        label: "Attribute Condition"
        grid-rows: 2
        grid-gap: 20
        style: {
          fill: "#f5f4fe"
          stroke: "#AFA9EC"
          border-radius: 4
          bold: true
        }

        condition_value: {
          label: "attribute.repository_owner == \"my-org\""
          shape: rectangle
          style: {
            fill: "#ffffff"
            stroke: "#AFA9EC"
            border-radius: 4
            font-size: 13
            bold: false
          }
        }

        condition_desc: {
          label: "A filter that decides which tokens are actually allowed in.\nOnly tokens matching this expression pass through.\nWithout this, any GitHub Actions workflow in the world could authenticate."
          shape: text
          style: {
            font-size: 12
            font-color: gray
            bold: false
          }
        }
      }

      github_issuer -> github_mapping -> github_condition: {
        style: {
          stroke: "#534AB7"
          stroke-dash: 3
        }
      }
    }
  }
}
