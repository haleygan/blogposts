direction: right

# GitHub Boundary (Left Side)
github: GitHub {
  style.fill: "#f9f9f9"

  github_action: GitHub Action\n(Holding Federated STS Token) {
    shape: rectangle
  }
}

# GCP Boundary (Right Side)
gcp: Google Cloud Platform {
  style.fill: "#f0f4f8"

  gcp_iam: IAM Service\n(generateAccessToken) {
    shape: rectangle
    style.fill: "#1a73e8"
    style.font-color: "#ffffff"
  }

  target_sa: Target Service Account {
    label: "Target Service Account\n(Validates WIF Principal\nin IAM Policy via Attribute Condition)"
    shape: rectangle
    style.fill: "#ffffff"
  }

  gcp_resources: Artifact Registry (GCP Resource) {
    shape: rectangle
  }
}

# Interactions
github.github_action -> gcp.gcp_iam: 1. Request OAuth2 Access Token\n(Passes STS Token & Target SA Email)
gcp.gcp_iam -> gcp.target_sa: 2. Check IAM Policy Binding

gcp.gcp_iam -> github.github_action: 3. Return Short-Lived GCP Access Token
github.github_action -> gcp.gcp_resources: 4. Call GCP APIs using Access Token
